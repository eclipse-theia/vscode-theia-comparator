{
    "compilerOptions": {
        "strict": false,
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "lib",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "src"
    ]
}
